          "android": {
            "fonts": [
              {
                "fontFamily": "Geist",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Geist-Thin.ttf",
                    "weight": 100
                  },
                  {
                    "path": "./assets/fonts/Geist-ThinItalic.ttf",
                    "weight": 100,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Geist-ExtraLight.ttf",
