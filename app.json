            "./assets/fonts/GeistMono-Regular.ttf",
            "./assets/fonts/GeistMono-SemiBold.ttf",
            "./assets/fonts/GeistMono-SemiBoldItalic.ttf",
            "./assets/fonts/GeistMono-Thin.ttf",
            "./assets/fonts/GeistMono-ThinItalic.ttf"
