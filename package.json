  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.49.0",
    "oxlint-plugin-react-native": "^0.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "ultracite": "^7.2.3"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
